{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Debug Main",
            "type": "cppdbg",
            "request": "launch",
            // Points to the actual executable name from the Makefile:
            "program": "${workspaceFolder}/main",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true, // change to 'false' if annoying.
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Make Build", 
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ]
}